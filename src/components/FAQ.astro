---
import type { Lang } from '../i18n/index.ts';
import { t } from '../i18n/index.ts';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const tr = t(lang);
const faq = tr.faq;
---

<section id="faq" class="py-24 bg-brand-surface" aria-labelledby="faq-title">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-2xl mx-auto mb-12">
      <span class="inline-block text-sm font-semibold text-brand-secondary tracking-wider uppercase mb-3">
        FAQ
      </span>
      <h2 id="faq-title" class="text-3xl sm:text-4xl font-extrabold text-brand-primary mb-4">
        {faq.title}
      </h2>
      <p class="text-lg text-brand-muted">
        {faq.subtitle}
      </p>
    </div>

    <div class="space-y-4">
      {faq.items.map((item) => (
        <details
          class="group bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden"
        >
          <summary class="flex items-center justify-between gap-4 px-6 py-4 cursor-pointer list-none font-semibold text-brand-primary hover:bg-brand-light/30 transition-colors">
            <h3 class="text-left pr-4">{item.question}</h3>
            <span class="flex-shrink-0 w-8 h-8 rounded-full bg-brand-light flex items-center justify-center text-brand-secondary group-open:rotate-180 transition-transform" aria-hidden="true">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </span>
          </summary>
          <div class="px-6 pb-4 pt-0 text-brand-muted leading-relaxed">
            <p>{item.answer}</p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
