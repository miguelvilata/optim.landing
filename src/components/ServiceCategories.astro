---
import type { Lang } from '../i18n/index.ts';
import { t } from '../i18n/index.ts';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const tr = t(lang);
const sc = tr.serviceCategories;
---

<section id="coberturas" class="py-24 bg-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center max-w-2xl mx-auto mb-16">
      <span class="inline-block text-sm font-semibold text-brand-secondary tracking-wider uppercase mb-3">
        Coberturas
      </span>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-brand-primary mb-4">
        {sc.title}
      </h2>
      <p class="text-lg text-brand-muted">
        {sc.subtitle}
      </p>
    </div>

    <!-- Two columns: insurance + utilities -->
    <div class="grid md:grid-cols-2 gap-8 max-w-3xl mx-auto">

      <!-- Insurance -->
      <div class="rounded-2xl border border-blue-100 bg-blue-50 p-8">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-xl bg-brand-secondary/10 flex items-center justify-center">
            <svg class="w-5 h-5 text-brand-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-brand-primary">{sc.insurance.label}</h3>
        </div>
        <ul class="space-y-3">
          {sc.insurance.items.map((item) => (
            <li class="flex items-center gap-3 bg-white rounded-xl px-4 py-3 shadow-sm">
              <span class="text-2xl" aria-hidden="true">{item.icon}</span>
              <span class="font-semibold text-brand-primary">{item.name}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Utilities -->
      <div class="rounded-2xl border border-orange-100 bg-orange-50 p-8">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-xl bg-orange-500/10 flex items-center justify-center">
            <svg class="w-5 h-5 text-orange-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-brand-primary">{sc.utilities.label}</h3>
        </div>
        <ul class="space-y-3">
          {sc.utilities.items.map((item) => (
            <li class="flex items-center gap-3 bg-white rounded-xl px-4 py-3 shadow-sm">
              <span class="text-2xl" aria-hidden="true">{item.icon}</span>
              <span class="font-semibold text-brand-primary">{item.name}</span>
            </li>
          ))}
        </ul>
      </div>

    </div>

    <!-- Bottom note -->
    <p class="text-center text-brand-muted text-sm mt-10">
      ¿Tienes otro tipo de gasto recurrente? Puedes registrar cualquier contrato personalizado.
    </p>
  </div>
</section>
