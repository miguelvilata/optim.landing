---
import type { Lang } from '../i18n/index.ts';
import { t } from '../i18n/index.ts';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const tr = t(lang);
const s = tr.screenshots;
---

<section id="screenshots" class="py-24 bg-brand-primary overflow-hidden">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-2xl mx-auto mb-16">
      <span class="inline-block text-sm font-semibold text-brand-secondary tracking-wider uppercase mb-3">
        App
      </span>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-white mb-4">
        {s.title}
      </h2>
      <p class="text-lg text-white/60">
        {s.subtitle}
      </p>
    </div>

    <!-- Carousel -->
    <div class="relative max-w-xs mx-auto" id="screenshots-carousel">
      <!-- Phone frame with sliding images -->
      <div class="relative mx-auto" style="width: 260px;">
        <!-- Outer phone frame -->
        <div class="bg-brand-dark rounded-[3rem] p-3 shadow-2xl shadow-black/60 border border-white/15">
          <div class="rounded-[2.5rem] overflow-hidden bg-black" style="height: 520px; position: relative;">
            <!-- Slides -->
            {s.items.map((item, i) => (
              <div
                class="carousel-slide absolute inset-0 transition-opacity duration-500"
                data-index={i}
                style={i === 0 ? "opacity: 1;" : "opacity: 0; pointer-events: none;"}
              >
                <img
                  src={item.src}
                  alt={item.alt}
                  class="w-full h-full object-cover object-top"
                  loading={i === 0 ? "eager" : "lazy"}
                />
              </div>
            ))}
          </div>
        </div>

        <!-- Glow effect -->
        <div class="absolute inset-0 rounded-[3rem] bg-brand-secondary/10 blur-2xl -z-10 scale-110" aria-hidden="true"></div>
      </div>

      <!-- Caption -->
      <div class="mt-8 text-center min-h-[3rem]" aria-live="polite">
        {s.items.map((item, i) => (
          <p
            class="carousel-caption text-white/70 text-sm leading-relaxed px-4 transition-opacity duration-300"
            data-index={i}
            style={i === 0 ? "opacity: 1;" : "opacity: 0; position: absolute; inset: 0;"}
          >
            {item.caption}
          </p>
        ))}
      </div>

      <!-- Dot indicators -->
      <div class="flex justify-center gap-2 mt-6" role="tablist" aria-label="Pantallas de la app">
        {s.items.map((item, i) => (
          <button
            class="carousel-dot w-2.5 h-2.5 rounded-full transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-white/50"
            data-index={i}
            role="tab"
            aria-selected={i === 0 ? "true" : "false"}
            aria-label={item.alt}
            style={i === 0 ? "background: rgb(96 165 250); transform: scale(1.2);" : "background: rgba(255,255,255,0.3);"}
          ></button>
        ))}
      </div>

      <!-- Prev / Next arrows -->
      <button
        id="carousel-prev"
        class="absolute left-0 top-1/3 -translate-x-12 -translate-y-1/2 w-10 h-10 rounded-full bg-white/10 border border-white/20 flex items-center justify-center text-white hover:bg-white/20 transition-colors focus:outline-none focus:ring-2 focus:ring-white/40"
        aria-label="Anterior"
        style="top: 260px;"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
      </button>
      <button
        id="carousel-next"
        class="absolute right-0 top-1/3 translate-x-12 -translate-y-1/2 w-10 h-10 rounded-full bg-white/10 border border-white/20 flex items-center justify-center text-white hover:bg-white/20 transition-colors focus:outline-none focus:ring-2 focus:ring-white/40"
        aria-label="Siguiente"
        style="top: 260px;"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </button>
    </div>
  </div>
</section>

<script>
  const total = document.querySelectorAll('.carousel-slide').length;
  let current = 0;
  let autoTimer: ReturnType<typeof setInterval>;

  function goTo(index: number) {
    const slides = document.querySelectorAll<HTMLElement>('.carousel-slide');
    const captions = document.querySelectorAll<HTMLElement>('.carousel-caption');
    const dots = document.querySelectorAll<HTMLButtonElement>('.carousel-dot');

    slides[current].style.opacity = '0';
    slides[current].style.pointerEvents = 'none';
    captions[current].style.opacity = '0';
    captions[current].style.position = 'absolute';
    dots[current].style.background = 'rgba(255,255,255,0.3)';
    dots[current].style.transform = 'scale(1)';
    dots[current].setAttribute('aria-selected', 'false');

    current = (index + total) % total;

    slides[current].style.opacity = '1';
    slides[current].style.pointerEvents = 'auto';
    captions[current].style.opacity = '1';
    captions[current].style.position = 'static';
    dots[current].style.background = 'rgb(96 165 250)';
    dots[current].style.transform = 'scale(1.2)';
    dots[current].setAttribute('aria-selected', 'true');
  }

  function startAuto() {
    autoTimer = setInterval(() => goTo(current + 1), 4000);
  }

  function stopAuto() {
    clearInterval(autoTimer);
  }

  document.getElementById('carousel-next')?.addEventListener('click', () => { stopAuto(); goTo(current + 1); startAuto(); });
  document.getElementById('carousel-prev')?.addEventListener('click', () => { stopAuto(); goTo(current - 1); startAuto(); });

  document.querySelectorAll<HTMLButtonElement>('.carousel-dot').forEach((dot) => {
    dot.addEventListener('click', () => {
      stopAuto();
      goTo(Number(dot.dataset.index));
      startAuto();
    });
  });

  const carousel = document.getElementById('screenshots-carousel');
  carousel?.addEventListener('mouseenter', stopAuto);
  carousel?.addEventListener('mouseleave', startAuto);

  // Swipe support
  let touchStartX = 0;
  let touchStartY = 0;

  carousel?.addEventListener('touchstart', (e: TouchEvent) => {
    touchStartX = e.touches[0].clientX;
    touchStartY = e.touches[0].clientY;
  }, { passive: true });

  carousel?.addEventListener('touchend', (e: TouchEvent) => {
    const deltaX = e.changedTouches[0].clientX - touchStartX;
    const deltaY = e.changedTouches[0].clientY - touchStartY;

    // Solo actuar si el gesto es claramente horizontal
    if (Math.abs(deltaX) < 40 || Math.abs(deltaX) < Math.abs(deltaY)) return;

    stopAuto();
    if (deltaX < 0) {
      goTo(current + 1);
    } else {
      goTo(current - 1);
    }
    startAuto();
  }, { passive: true });

  startAuto();
</script>
