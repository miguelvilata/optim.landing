---
import type { Lang } from '../i18n/index.ts';
import { t } from '../i18n/index.ts';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const tr = t(lang);
const s = tr.screenshots;
---

<section id="screenshots" class="py-24 bg-brand-primary overflow-hidden">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-2xl mx-auto mb-16">
      <span class="inline-block text-sm font-semibold text-brand-secondary tracking-wider uppercase mb-3">
        App
      </span>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-white mb-4">
        {s.title}
      </h2>
      <p class="text-lg text-white/60">
        {s.subtitle}
      </p>
    </div>

    <!-- Mockup screens row -->
    <div class="flex justify-center items-end gap-4 sm:gap-6" aria-hidden="true">

      <!-- Screen 1: Dashboard -->
      <div class="hidden sm:block w-48 flex-shrink-0 opacity-60 translate-y-8">
        <div class="bg-brand-dark rounded-3xl p-2.5 border border-white/10 shadow-2xl">
          <div class="bg-white rounded-2xl overflow-hidden" style="height:380px">
            <div class="bg-brand-primary p-4">
              <p class="text-white/60 text-xs">Total</p>
              <p class="text-white text-2xl font-bold">€ 284</p>
            </div>
            <div class="p-3 space-y-2">
              {['Auto', 'Hogar', 'Vida', 'Salud'].map(name => (
                <div class="bg-gray-50 rounded-xl p-2.5 flex items-center gap-2">
                  <div class="w-7 h-7 rounded-lg bg-brand-light flex items-center justify-center">
                    <div class="w-3 h-3 rounded-full bg-brand-secondary"></div>
                  </div>
                  <div>
                    <div class="text-xs font-semibold text-gray-700">{name}</div>
                    <div class="text-xs text-gray-400">Activo</div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>

      <!-- Screen 2: Main (center, larger) -->
      <div class="w-56 sm:w-64 flex-shrink-0 relative z-10">
        <div class="bg-brand-dark rounded-[2.5rem] p-3 border border-white/20 shadow-2xl shadow-black/50">
          <div class="bg-white rounded-[2rem] overflow-hidden" style="height:480px">
            <!-- Header -->
            <div class="bg-brand-primary px-5 py-5">
              <div class="flex justify-between items-start">
                <div>
                  <p class="text-white/60 text-xs">Bienvenido</p>
                  <p class="text-white font-bold text-lg">Carlos</p>
                </div>
                <div class="w-9 h-9 rounded-full bg-white/20 flex items-center justify-center">
                  <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd"/>
                  </svg>
                </div>
              </div>
            </div>

            <!-- Summary card -->
            <div class="px-4 pt-4">
              <div class="bg-gradient-to-br from-brand-secondary to-blue-400 rounded-2xl p-4 text-white">
                <p class="text-xs text-white/70">Gasto mensual</p>
                <p class="text-3xl font-extrabold">€ 284</p>
                <div class="flex gap-2 mt-3">
                  <div class="flex-1 bg-white/20 rounded-xl p-2 text-center">
                    <p class="text-xs text-white/70">Seguros</p>
                    <p class="text-sm font-bold">€ 210</p>
                  </div>
                  <div class="flex-1 bg-white/20 rounded-xl p-2 text-center">
                    <p class="text-xs text-white/70">Gastos</p>
                    <p class="text-sm font-bold">€ 74</p>
                  </div>
                </div>
              </div>
            </div>

            <!-- Alerts -->
            <div class="px-4 pt-4">
              <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-2">Proximos</p>
              <div class="space-y-2">
                {[
                  { e: '🚗', n: 'Auto', d: '5 dias', c: 'bg-orange-50 text-orange-600' },
                  { e: '🏠', n: 'Hogar', d: '20 dias', c: 'bg-blue-50 text-blue-600' },
                  { e: '❤️', n: 'Vida', d: '45 dias', c: 'bg-green-50 text-green-600' },
                ].map(item => (
                  <div class="flex items-center gap-3 bg-gray-50 rounded-xl p-2.5">
                    <span class="text-lg">{item.e}</span>
                    <div class="flex-1">
                      <p class="text-xs font-semibold text-gray-700">{item.n}</p>
                    </div>
                    <span class={`text-xs font-semibold px-2 py-0.5 rounded-full ${item.c}`}>{item.d}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Screen 3: Analytics -->
      <div class="hidden sm:block w-48 flex-shrink-0 opacity-60 translate-y-8">
        <div class="bg-brand-dark rounded-3xl p-2.5 border border-white/10 shadow-2xl">
          <div class="bg-white rounded-2xl overflow-hidden" style="height:380px">
            <div class="bg-brand-primary p-4">
              <p class="text-white/60 text-xs">Analisis</p>
              <p class="text-white text-lg font-bold">Marzo 2025</p>
            </div>
            <div class="p-4">
              <!-- Bar chart mockup -->
              <div class="space-y-3">
                {[
                  { label: 'Auto', pct: 74, color: 'bg-brand-secondary' },
                  { label: 'Hogar', pct: 54, color: 'bg-indigo-400' },
                  { label: 'Vida', pct: 38, color: 'bg-teal-400' },
                  { label: 'Salud', pct: 28, color: 'bg-purple-400' },
                ].map(bar => (
                  <div>
                    <div class="flex justify-between text-xs text-gray-500 mb-1">
                      <span>{bar.label}</span>
                      <span>{bar.pct}%</span>
                    </div>
                    <div class="bg-gray-100 rounded-full h-2">
                      <div
                        class={`h-2 rounded-full ${bar.color}`}
                        style={`width: ${bar.pct}%`}
                      ></div>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
