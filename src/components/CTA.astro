---
import type { Lang } from '../i18n/index.ts';
import { t } from '../i18n/index.ts';
import { GOOGLE_PLAY_URL, APP_STORE_URL } from '../config.ts';
import AppLogo from './AppLogo.astro';
import QRCode from 'qrcode';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const tr = t(lang);
const c = tr.cta;

const hasGooglePlay = GOOGLE_PLAY_URL !== '#';
const hasAppStore = APP_STORE_URL !== '#';

const googlePlayQrDataUrl = hasGooglePlay
  ? await QRCode.toDataURL(GOOGLE_PLAY_URL, { width: 160, margin: 1 })
  : null;
const appStoreQrDataUrl = hasAppStore
  ? await QRCode.toDataURL(APP_STORE_URL, { width: 160, margin: 1 })
  : null;
---

<section id="download" class="py-24 bg-white">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="relative rounded-3xl bg-brand-gradient overflow-hidden p-10 sm:p-16 text-center shadow-2xl">
      <!-- Background decoration -->
      <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
        <div class="absolute -top-20 -right-20 w-80 h-80 rounded-full bg-brand-secondary opacity-10 blur-3xl"></div>
        <div class="absolute -bottom-20 -left-20 w-80 h-80 rounded-full bg-blue-400 opacity-10 blur-3xl"></div>
      </div>

      <div class="relative">
        <!-- Icon -->
        <div class="inline-flex mb-8">
          <AppLogo size={80} />
        </div>

        <h2 class="text-3xl sm:text-4xl font-extrabold text-white mb-4">
          {c.title}
        </h2>
        <p class="text-lg text-white/70 mb-10 max-w-xl mx-auto">
          {c.subtitle}
        </p>

        <!-- Download buttons -->
        <div class="flex flex-wrap justify-center gap-4">
          {hasGooglePlay && (
            <a
              href={GOOGLE_PLAY_URL}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-3 px-6 py-3.5 bg-white text-brand-primary font-bold rounded-2xl hover:bg-brand-light transition-all duration-200 shadow-lg hover:-translate-y-0.5"
              aria-label={c.googlePlay}
            >
              <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M3.609 1.814L13.792 12 3.61 22.186a.996.996 0 0 1-.61-.92V2.734a1 1 0 0 1 .609-.92zm10.89 10.893l2.302 2.302-10.937 6.333 8.635-8.635zm3.199-3.198l2.807 1.626a1 1 0 0 1 0 1.73l-2.808 1.626L15.206 12l2.492-2.491zM5.864 2.658L16.802 8.99l-2.302 2.302-8.636-8.636z"/>
              </svg>
              {c.googlePlay}
            </a>
          )}
          {hasAppStore && (
            <a
              href={APP_STORE_URL}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-3 px-6 py-3.5 bg-white text-brand-primary font-bold rounded-2xl hover:bg-brand-light transition-all duration-200 shadow-lg hover:-translate-y-0.5"
              aria-label={c.appStore}
            >
              <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.2-1.2.41-2.35 1.05-3.16z"/>
              </svg>
              {c.appStore}
            </a>
          )}
        </div>

        <!-- QR codes: desktop only -->
        {(googlePlayQrDataUrl || appStoreQrDataUrl) && (
          <div class="hidden lg:flex justify-center gap-10 mt-10 pt-10 border-t border-white/20">
            <p class="sr-only">{c.qrTitle}</p>
            {googlePlayQrDataUrl && (
              <a
                href={GOOGLE_PLAY_URL}
                target="_blank"
                rel="noopener noreferrer"
                class="flex flex-col items-center gap-2 text-white/90 hover:text-white transition-colors"
                aria-label={c.qrAriaGooglePlay}
              >
                <img
                  src={googlePlayQrDataUrl}
                  alt=""
                  width="160"
                  height="160"
                  class="rounded-xl bg-white p-2 shadow-lg"
                />
                <span class="text-sm font-medium">{c.qrAndroid}</span>
              </a>
            )}
            {appStoreQrDataUrl && (
              <a
                href={APP_STORE_URL}
                target="_blank"
                rel="noopener noreferrer"
                class="flex flex-col items-center gap-2 text-white/90 hover:text-white transition-colors"
                aria-label={c.qrAriaAppStore}
              >
                <img
                  src={appStoreQrDataUrl}
                  alt=""
                  width="160"
                  height="160"
                  class="rounded-xl bg-white p-2 shadow-lg"
                />
                <span class="text-sm font-medium">{c.qrIos}</span>
              </a>
            )}
          </div>
        )}

        <!-- Waitlist CTA -->
        <div class="flex justify-center mt-10">
          <a
            href={`/${lang}/waitlist`}
            class="inline-flex items-center gap-3 px-8 py-4 bg-white/10 border border-white/30 text-white font-bold rounded-2xl hover:bg-white/20 transition-all duration-200"
          >
            <svg class="w-5 h-5 flex-shrink-0 text-brand-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
            </svg>
            {c.waitlist}
          </a>
        </div>

        <p class="mt-6 text-sm text-white/40">{c.note}</p>
      </div>
    </div>
  </div>
</section>
