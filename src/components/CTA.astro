---
import type { Lang } from '../i18n/index.ts';
import { t } from '../i18n/index.ts';
import { GOOGLE_PLAY_URL, APP_STORE_URL } from '../config.ts';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const tr = t(lang);
const c = tr.cta;
---

<section id="download" class="py-24 bg-white">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="relative rounded-3xl bg-brand-gradient overflow-hidden p-10 sm:p-16 text-center shadow-2xl">
      <!-- Background decoration -->
      <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
        <div class="absolute -top-20 -right-20 w-80 h-80 rounded-full bg-brand-secondary opacity-10 blur-3xl"></div>
        <div class="absolute -bottom-20 -left-20 w-80 h-80 rounded-full bg-blue-400 opacity-10 blur-3xl"></div>
      </div>

      <div class="relative">
        <!-- Icon -->
        <div class="inline-flex w-20 h-20 rounded-3xl bg-white/10 border border-white/20 items-center justify-center mb-8">
          <svg class="w-10 h-10 text-white" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.7 9.05 7.42c1.39.07 2.35.74 3.18.8 1.21-.21 2.37-.92 3.65-.84 1.55.12 2.72.73 3.48 1.9-3.14 1.88-2.4 5.98.69 7.14-.49 1.29-1.14 2.56-3 3.86zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z"/>
          </svg>
        </div>

        <h2 class="text-3xl sm:text-4xl font-extrabold text-white mb-4">
          {c.title}
        </h2>
        <p class="text-lg text-white/70 mb-10 max-w-xl mx-auto">
          {c.subtitle}
        </p>

        <!-- Store buttons -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
          <!-- Google Play -->
          <a
            href={GOOGLE_PLAY_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-3 px-6 py-3.5 bg-white text-brand-primary font-bold rounded-2xl hover:bg-brand-light transition-all duration-200 shadow-xl hover:-translate-y-0.5 min-w-[200px]"
          >
            <svg class="w-7 h-7 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.7 9.05 7.42c1.39.07 2.35.74 3.18.8 1.21-.21 2.37-.92 3.65-.84 1.55.12 2.72.73 3.48 1.9-3.14 1.88-2.4 5.98.69 7.14-.49 1.29-1.14 2.56-3 3.86zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z"/>
            </svg>
            <div class="text-left">
              <p class="text-xs text-brand-primary/60 leading-none mb-0.5">Disponible en</p>
              <p class="text-sm font-bold leading-none">Google Play</p>
            </div>
          </a>

          <!-- App Store (coming soon) -->
          <div
            class="inline-flex items-center gap-3 px-6 py-3.5 bg-white/10 border border-white/20 text-white/60 rounded-2xl min-w-[200px] cursor-not-allowed"
            title="Proximamente en App Store"
            aria-label="App Store - Proximamente"
          >
            <svg class="w-7 h-7 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
            </svg>
            <div class="text-left">
              <p class="text-xs text-white/40 leading-none mb-0.5">Proximamente en</p>
              <p class="text-sm font-semibold leading-none">{c.appStore}</p>
            </div>
          </div>
        </div>

        <p class="mt-6 text-sm text-white/40">{c.note}</p>
      </div>
    </div>
  </div>
</section>
