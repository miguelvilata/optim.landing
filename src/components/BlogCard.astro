---
import type { Lang } from '../i18n/index.ts';
import { t } from '../i18n/index.ts';

interface Props {
  lang: Lang;
  slug: string;
  title: string;
  description: string;
  pubDate: Date;
  tags: string[];
  image?: { src: string; alt: string };
}

const { lang, slug, title, description, pubDate, tags, image } = Astro.props;
const tr = t(lang);

const locale = lang === 'es' ? 'es-ES' : lang === 'pt' ? 'pt-PT' : 'en-GB';
const formattedDate = pubDate.toLocaleDateString(locale, {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="bg-white rounded-2xl border border-brand-border overflow-hidden hover:shadow-lg transition-shadow duration-200 flex flex-col">
  {image && (
    <a href={`/${lang}/blog/${slug}`} tabindex="-1" aria-hidden="true">
      <img
        src={image.src}
        alt={image.alt}
        class="w-full h-48 object-cover"
        loading="lazy"
      />
    </a>
  )}
  <div class="p-6 flex flex-col flex-1">
    {tags.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-3">
        {tags.map((tag) => (
          <span class="text-xs font-medium text-brand-secondary bg-brand-light px-2.5 py-1 rounded-full">
            {tag}
          </span>
        ))}
      </div>
    )}
    <h2 class="text-lg font-bold text-brand-primary mb-2 leading-snug">
      <a href={`/${lang}/blog/${slug}`} class="hover:text-brand-secondary transition-colors">
        {title}
      </a>
    </h2>
    <p class="text-brand-muted text-sm leading-relaxed mb-4 flex-1 line-clamp-3">
      {description}
    </p>
    <div class="flex items-center justify-between mt-auto pt-4 border-t border-brand-border">
      <time class="text-xs text-brand-muted" datetime={pubDate.toISOString()}>
        {formattedDate}
      </time>
      <a
        href={`/${lang}/blog/${slug}`}
        class="text-sm font-semibold text-brand-secondary hover:text-blue-700 transition-colors"
      >
        {tr.blog.readMore} →
      </a>
    </div>
  </div>
</article>
