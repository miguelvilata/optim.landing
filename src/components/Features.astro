---
import type { Lang } from '../i18n/index.ts';
import { t } from '../i18n/index.ts';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const tr = t(lang);
const f = tr.features;

const iconPaths: Record<string, string> = {
  shield: 'M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z',
  bell: 'M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0',
  chart: 'M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z',
  building: 'M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21',
  lock: 'M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z',
  refresh: 'M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99',
};

const featureColors = [
  { bg: 'bg-blue-50', icon: 'text-brand-secondary', border: 'border-blue-100' },
  { bg: 'bg-orange-50', icon: 'text-orange-500', border: 'border-orange-100' },
  { bg: 'bg-indigo-50', icon: 'text-indigo-500', border: 'border-indigo-100' },
  { bg: 'bg-teal-50', icon: 'text-teal-500', border: 'border-teal-100' },
  { bg: 'bg-green-50', icon: 'text-green-600', border: 'border-green-100' },
  { bg: 'bg-purple-50', icon: 'text-purple-500', border: 'border-purple-100' },
];
---

<section id="features" class="py-24 bg-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="text-center max-w-2xl mx-auto mb-16">
      <span class="inline-block text-sm font-semibold text-brand-secondary tracking-wider uppercase mb-3">
        Features
      </span>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-brand-primary mb-4">
        {f.title}
      </h2>
      <p class="text-lg text-brand-muted">
        {f.subtitle}
      </p>
    </div>

    <!-- Features grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {f.items.map((item, i) => {
        const color = featureColors[i % featureColors.length];
        const iconPath = iconPaths[item.icon] || iconPaths.shield;
        return (
          <article class={`p-6 rounded-2xl border ${color.border} ${color.bg} hover:shadow-md transition-shadow duration-300`}>
            <div class={`w-12 h-12 rounded-xl flex items-center justify-center bg-white shadow-sm mb-5`}>
              <svg class={`w-6 h-6 ${color.icon}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d={iconPath} />
              </svg>
            </div>
            <h3 class="text-lg font-bold text-brand-primary mb-2">{item.title}</h3>
            <p class="text-sm text-brand-muted leading-relaxed">{item.description}</p>
          </article>
        );
      })}
    </div>
  </div>
</section>
