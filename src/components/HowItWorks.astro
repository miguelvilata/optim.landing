---
import type { Lang } from '../i18n/index.ts';
import { t } from '../i18n/index.ts';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const tr = t(lang);
const h = tr.howItWorks;
---

<section id={tr.anchors.howItWorks} class="py-24 bg-brand-surface">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="text-center max-w-2xl mx-auto mb-16">
      <span class="inline-block text-sm font-semibold text-brand-secondary tracking-wider uppercase mb-3">
        Proceso
      </span>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-brand-primary mb-4">
        {h.title}
      </h2>
      <p class="text-lg text-brand-muted">
        {h.subtitle}
      </p>
    </div>

    <!-- Steps -->
    <div class="grid md:grid-cols-3 gap-8 relative">
      <!-- Connector line (desktop only) -->
      <div class="hidden md:block absolute top-12 left-1/3 right-1/3 h-0.5 bg-gradient-to-r from-brand-light via-brand-secondary/30 to-brand-light" aria-hidden="true"></div>

      {h.steps.map((step, i) => (
        <div class="relative text-center flex flex-col items-center">
          <!-- Step number circle -->
          <div class="relative z-10 w-24 h-24 rounded-full bg-brand-primary flex flex-col items-center justify-center shadow-lg shadow-brand-primary/20 mb-6">
            <span class="text-xs font-bold text-brand-secondary/80 tracking-widest">{step.number}</span>
            <svg class="w-8 h-8 text-white mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              {i === 0 && (
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
              )}
              {i === 1 && (
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v6m3-3H9m12 0a9 9 0 11-18 0 9 9 0 0118 0z" />
              )}
              {i === 2 && (
                <path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0" />
              )}
            </svg>
          </div>

          <h3 class="text-xl font-bold text-brand-primary mb-3">{step.title}</h3>
          <p class="text-lg text-brand-muted leading-relaxed max-w-xs">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
