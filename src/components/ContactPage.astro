---
import type { Lang } from '../i18n/index.ts';
import { t } from '../i18n/index.ts';
import { SUPABASE_URL, SUPABASE_ANON_KEY } from '../config.ts';
import Navbar from './Navbar.astro';
import Footer from './Footer.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const tr = t(lang);
const c = tr.contact;
const termsUrl = `/${lang}/terms`;
const privacyUrl = `/${lang}/privacy`;
const submitUrl = `${SUPABASE_URL}/functions/v1/submit-contact`;
const anonKey = SUPABASE_ANON_KEY;
---

<Navbar lang={lang} />

<main class="min-h-screen bg-brand-surface pt-16">
  <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-28">

    <!-- Breadcrumb -->
    <nav class="mb-8" aria-label="Breadcrumb">
      <ol class="flex items-center gap-2 text-sm text-brand-muted">
        <li>
          <a href={`/${lang}/`} class="hover:text-brand-secondary transition-colors">Optim</a>
        </li>
        <li aria-hidden="true">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </li>
        <li class="text-brand-primary font-medium" aria-current="page">{c.title}</li>
      </ol>
    </nav>

    <h1 class="text-4xl sm:text-5xl font-extrabold text-brand-primary mb-4">{c.title}</h1>
    <p class="text-lg text-brand-muted mb-10">{c.subtitle}</p>

    <!-- Form card -->
    <div class="bg-white rounded-3xl shadow-lg border border-gray-100 p-8 sm:p-10">
      <form id="contact-form" novalidate>
        <!-- Honeypot -->
        <input
          type="text"
          name="website"
          tabindex="-1"
          autocomplete="off"
          aria-hidden="true"
          style="position:absolute;left:-9999px;opacity:0;pointer-events:none;"
        />

        <div class="flex flex-col gap-4">
          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <label for="c-name" class="block text-sm font-medium text-brand-primary mb-1.5">
                {c.namePlaceholder} *
              </label>
              <input
                id="c-name"
                type="text"
                name="name"
                required
                placeholder={c.namePlaceholder}
                autocomplete="name"
                class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-brand-secondary text-brand-primary placeholder-brand-muted bg-white text-base"
              />
            </div>
            <div>
              <label for="c-email" class="block text-sm font-medium text-brand-primary mb-1.5">
                Email *
              </label>
              <input
                id="c-email"
                type="email"
                name="email"
                required
                placeholder={c.emailPlaceholder}
                autocomplete="email"
                class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-brand-secondary text-brand-primary placeholder-brand-muted bg-white text-base"
              />
            </div>
          </div>

          <div>
            <label for="c-subject" class="block text-sm font-medium text-brand-primary mb-1.5">
              {c.subjectPlaceholder}
            </label>
            <input
              id="c-subject"
              type="text"
              name="subject"
              placeholder={c.subjectPlaceholder}
              class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-brand-secondary text-brand-primary placeholder-brand-muted bg-white text-base"
            />
          </div>

          <div>
            <label for="c-message" class="block text-sm font-medium text-brand-primary mb-1.5">
              {c.messagePlaceholder.replace('...', '')} *
            </label>
            <textarea
              id="c-message"
              name="message"
              required
              rows="5"
              placeholder={c.messagePlaceholder}
              class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-brand-secondary text-brand-primary placeholder-brand-muted bg-white text-base resize-none"
            ></textarea>
          </div>

          <!-- Consent checkboxes -->
          <div class="flex flex-col gap-2 text-left pt-1">
            <label class="flex items-start gap-2.5 cursor-pointer">
              <input
                type="checkbox"
                name="consent_terms"
                id="consent-terms"
                class="mt-0.5 w-4 h-4 flex-shrink-0 accent-brand-secondary cursor-pointer"
              />
              <span class="text-sm text-brand-muted">
                {c.consentTermsPrefix}
                <a href={termsUrl} target="_blank" class="text-brand-secondary hover:underline">{tr.footer.terms}</a>
                {c.consentTermsAnd}
                <a href={privacyUrl} target="_blank" class="text-brand-secondary hover:underline">{tr.footer.privacy}</a>*
              </span>
            </label>
            <label class="flex items-start gap-2.5 cursor-pointer">
              <input
                type="checkbox"
                name="consent_marketing"
                id="consent-marketing"
                class="mt-0.5 w-4 h-4 flex-shrink-0 accent-brand-secondary cursor-pointer"
              />
              <span class="text-sm text-brand-muted">{c.consentMarketing}</span>
            </label>
          </div>

          <p class="text-xs text-brand-muted/60">{c.required}</p>

          <button
            type="submit"
            id="contact-submit"
            class="w-full px-8 py-4 bg-brand-secondary text-white font-bold rounded-xl hover:bg-blue-600 transition-all duration-200 disabled:opacity-60 disabled:cursor-not-allowed text-base"
          >
            {c.submit}
          </button>
        </div>
      </form>

      <!-- Status messages -->
      <div id="contact-status" class="mt-6 hidden text-center">
        <div id="contact-icon" class="flex justify-center mb-3"></div>
        <p id="contact-msg" class="text-base font-semibold"></p>
        <p id="contact-detail" class="text-sm text-brand-muted mt-2 hidden"></p>
      </div>
    </div>

  </div>
</main>

<Footer lang={lang} />

<script define:vars={{ submitUrl, anonKey, lang, c }}>
  const form = document.getElementById('contact-form');
  const submitBtn = document.getElementById('contact-submit');
  const statusDiv = document.getElementById('contact-status');
  const iconEl = document.getElementById('contact-icon');
  const msgEl = document.getElementById('contact-msg');
  const detailEl = document.getElementById('contact-detail');

  const iconSuccess = `<svg class="w-12 h-12 text-green-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`;
  const iconError = `<svg class="w-12 h-12 text-red-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`;

  function showStatus(msg, detail, isError) {
    statusDiv.classList.remove('hidden');
    iconEl.innerHTML = isError ? iconError : iconSuccess;
    msgEl.textContent = msg;
    msgEl.className = `text-base font-semibold ${isError ? 'text-red-600' : 'text-green-700'}`;
    if (detail) {
      detailEl.textContent = detail;
      detailEl.classList.remove('hidden');
    } else {
      detailEl.classList.add('hidden');
    }
  }

  function resetSubmitBtn() {
    submitBtn.disabled = false;
    submitBtn.textContent = c.submit;
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    if (form.elements['website'].value) return;

    const name = form.elements['name'].value.trim();
    const email = form.elements['email'].value.trim();
    const subject = form.elements['subject'].value.trim();
    const message = form.elements['message'].value.trim();
    const consentTerms = form.elements['consent_terms'].checked;
    const consentMarketing = form.elements['consent_marketing'].checked;

    if (!name || !email || !message) {
      showStatus(c.errorValidation, null, true);
      return;
    }

    if (!consentTerms) {
      showStatus(c.errorConsent, null, true);
      return;
    }

    submitBtn.disabled = true;
    submitBtn.textContent = c.submitting;

    try {
      const res = await fetch(submitUrl, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': `Bearer ${anonKey}`,
        },
        body: JSON.stringify({
          name,
          email,
          subject: subject || undefined,
          message,
          lang,
          consent_terms: true,
          consent_marketing: consentMarketing,
        }),
      });

      if (res.ok) {
        form.classList.add('hidden');
        showStatus(c.successTitle, c.successDetail, false);
      } else if (res.status === 429) {
        showStatus(c.errorRateLimit, null, true);
        resetSubmitBtn();
      } else {
        showStatus(c.errorServer, null, true);
        resetSubmitBtn();
      }
    } catch {
      showStatus(c.errorServer, null, true);
      resetSubmitBtn();
    }
  });
</script>
