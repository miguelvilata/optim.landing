---
import type { Lang } from '../i18n/index.ts';
import { t, aboutPageSlug } from '../i18n/index.ts';
import AppLogo from './AppLogo.astro';
import LanguageSelector from './LanguageSelector.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const tr = t(lang);
const f = tr.footer;
const year = new Date().getFullYear();
---

<footer class="bg-brand-primary border-t border-white/10">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8 mb-10">
      <!-- Brand -->
      <div class="sm:col-span-2 lg:col-span-1">
        <div class="flex items-center gap-3 mb-4">
          <AppLogo size={36} />
          <span class="text-white font-bold text-xl">Optim</span>
        </div>
        <p class="text-white/50 text-sm leading-relaxed max-w-xs">
          {f.tagline}
        </p>
      </div>

      <!-- Legal links -->
      <div>
        <h3 class="text-white/80 text-xs font-semibold uppercase tracking-wider mb-4">Legal</h3>
        <nav aria-label="Footer legal links">
          <ul class="space-y-3">
            <li>
              <a
                href={`/${lang}/privacy`}
                class="text-white/50 hover:text-white text-sm transition-colors"
              >
                {f.privacy}
              </a>
            </li>
            <li>
              <a
                href={`/${lang}/terms`}
                class="text-white/50 hover:text-white text-sm transition-colors"
              >
                {f.terms}
              </a>
            </li>
            <li>
              <a
                href={`/${lang}/${aboutPageSlug[lang]}`}
                class="text-white/50 hover:text-white text-sm transition-colors"
              >
                {f.about}
              </a>
            </li>
            <li>
              <a
                href={`/${lang}/contact`}
                class="text-white/50 hover:text-white text-sm transition-colors"
              >
                {f.contact}
              </a>
            </li>
          </ul>
        </nav>
      </div>

      <!-- Language selector -->
      <div>
        <h3 class="text-white/80 text-xs font-semibold uppercase tracking-wider mb-4">
          {f.language}
        </h3>
        <LanguageSelector lang={lang} />
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-white/10 pt-8 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-white/30 text-xs">
        &copy; {year} {f.copyright}
      </p>
      <p class="text-white/40 text-xs flex items-center gap-1.5">
        <svg class="w-3 h-3 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
        </svg>
        {f.cookieNotice}
      </p>
    </div>
  </div>
</footer>
