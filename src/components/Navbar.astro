---
import type { Lang } from '../i18n/index.ts';
import { t } from '../i18n/index.ts';
import AppLogo from './AppLogo.astro';
import LanguageSelector from './LanguageSelector.astro';
import { GOOGLE_PLAY_URL } from '../config.ts';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const tr = t(lang);
---

<header class="fixed top-0 left-0 right-0 z-50 bg-brand-primary/95 backdrop-blur-sm border-b border-white/10">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <nav class="flex items-center justify-between h-16" aria-label="Main navigation">
      <!-- Logo -->
      <a href={`/${lang}`} class="flex items-center gap-3 shrink-0" aria-label={tr.nav.logoAlt}>
        <AppLogo size={36} />
        <span class="text-white font-bold text-lg tracking-tight">Optim</span>
      </a>

      <!-- Desktop nav links -->
      <div class="hidden md:flex items-center gap-8">
        <a
          href={`/${lang}#features`}
          class="text-sm text-white/80 hover:text-white transition-colors"
        >
          {tr.nav.features}
        </a>
        <a
          href={`/${lang}#how-it-works`}
          class="text-sm text-white/80 hover:text-white transition-colors"
        >
          {tr.nav.howItWorks}
        </a>
        <a
          href={`/${lang}/waitlist`}
          class="text-sm text-brand-secondary hover:text-blue-400 font-semibold transition-colors flex items-center gap-1.5"
        >
          <span class="w-1.5 h-1.5 rounded-full bg-brand-secondary animate-pulse"></span>
          {tr.nav.waitlist}
        </a>
        <LanguageSelector lang={lang} />
        <a
          href={GOOGLE_PLAY_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="px-4 py-2 bg-brand-secondary hover:bg-blue-500 text-white text-sm font-semibold rounded-full transition-colors"
        >
          {tr.nav.download}
        </a>
      </div>

      <!-- Mobile: lang selector + CTA -->
      <div class="flex md:hidden items-center gap-3">
        <a
          href={`/${lang}/waitlist`}
          class="text-xs text-brand-secondary font-semibold flex items-center gap-1"
        >
          <span class="w-1.5 h-1.5 rounded-full bg-brand-secondary animate-pulse"></span>
          {tr.nav.waitlist}
        </a>
        <LanguageSelector lang={lang} />
        <a
          href={GOOGLE_PLAY_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="px-3 py-1.5 bg-brand-secondary text-white text-xs font-semibold rounded-full"
        >
          {tr.nav.download}
        </a>
      </div>
    </nav>
  </div>
</header>
