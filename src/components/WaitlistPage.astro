---
import type { Lang } from '../i18n/index.ts';
import { t } from '../i18n/index.ts';
import { SUPABASE_URL } from '../config.ts';
import Navbar from './Navbar.astro';
import Footer from './Footer.astro';
import ConfirmBanner from './ConfirmBanner.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const tr = t(lang);
const w = tr.waitlist;
const p = tr.waitlistPage;
const submitUrl = `${SUPABASE_URL}/functions/v1/submit-lead`;
---

<ConfirmBanner lang={lang} />
<Navbar lang={lang} />

<main class="min-h-screen bg-brand-surface pt-16">
  <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-28">

    <!-- Badge -->
    <div class="flex justify-center mb-6">
      <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-brand-secondary/10 text-brand-secondary text-sm font-semibold">
        <span class="w-2 h-2 rounded-full bg-brand-secondary animate-pulse"></span>
        {p.badge}
      </span>
    </div>

    <!-- Title -->
    <h1 class="text-4xl sm:text-5xl font-extrabold text-brand-primary text-center leading-tight mb-6">
      {p.title}
    </h1>
    <p class="text-lg text-brand-muted text-center mb-10 max-w-lg mx-auto">
      {p.subtitle}
    </p>

    <!-- Bullets -->
    <ul class="space-y-3 mb-12 max-w-sm mx-auto">
      {p.bullets.map((bullet: string) => (
        <li class="flex items-start gap-3 text-brand-muted">
          <svg class="w-5 h-5 text-brand-secondary flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
          <span>{bullet}</span>
        </li>
      ))}
    </ul>

    <!-- Form card -->
    <div class="bg-white rounded-3xl shadow-lg border border-gray-100 p-8 sm:p-10">
      <form id="waitlist-form" novalidate>
        <!-- Honeypot -->
        <input
          type="text"
          name="website"
          tabindex="-1"
          autocomplete="off"
          aria-hidden="true"
          style="position:absolute;left:-9999px;opacity:0;pointer-events:none;"
        />

        <div class="flex flex-col gap-4">
          <div>
            <label for="wl-name" class="block text-sm font-medium text-brand-primary mb-1.5">{w.namePlaceholder}</label>
            <input
              id="wl-name"
              type="text"
              name="name"
              placeholder={w.namePlaceholder}
              autocomplete="name"
              class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-brand-secondary text-brand-primary placeholder-brand-muted bg-white text-base"
            />
          </div>
          <div>
            <label for="wl-email" class="block text-sm font-medium text-brand-primary mb-1.5">Email *</label>
            <input
              id="wl-email"
              type="email"
              name="email"
              required
              placeholder={w.emailPlaceholder}
              autocomplete="email"
              class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-brand-secondary text-brand-primary placeholder-brand-muted bg-white text-base"
            />
          </div>
          <button
            type="submit"
            id="waitlist-submit"
            class="w-full px-8 py-4 bg-brand-secondary text-white font-bold rounded-xl hover:bg-blue-600 transition-all duration-200 disabled:opacity-60 disabled:cursor-not-allowed text-base"
          >
            {w.submit}
          </button>
        </div>
      </form>

      <!-- Status messages -->
      <div id="waitlist-status" class="mt-6 hidden text-center">
        <div id="waitlist-icon" class="flex justify-center mb-3"></div>
        <p id="waitlist-msg" class="text-base font-semibold"></p>
        <p id="waitlist-detail" class="text-sm text-brand-muted mt-2 hidden"></p>
      </div>

      <!-- Privacy note -->
      <p class="mt-6 text-xs text-brand-muted/70 text-center flex items-center justify-center gap-1.5">
        <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
        </svg>
        {p.privacyNote}
      </p>
    </div>

  </div>
</main>

<Footer lang={lang} />

<script define:vars={{ submitUrl, lang, w }}>
  const form = document.getElementById('waitlist-form');
  const submitBtn = document.getElementById('waitlist-submit');
  const statusDiv = document.getElementById('waitlist-status');
  const iconEl = document.getElementById('waitlist-icon');
  const msgEl = document.getElementById('waitlist-msg');
  const detailEl = document.getElementById('waitlist-detail');

  const iconSuccess = `<svg class="w-12 h-12 text-green-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`;
  const iconError = `<svg class="w-12 h-12 text-red-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`;

  function showStatus(msg, detail, isError) {
    statusDiv.classList.remove('hidden');
    iconEl.innerHTML = isError ? iconError : iconSuccess;
    msgEl.textContent = msg;
    msgEl.className = `text-base font-semibold ${isError ? 'text-red-600' : 'text-green-700'}`;
    if (detail) {
      detailEl.textContent = detail;
      detailEl.classList.remove('hidden');
    } else {
      detailEl.classList.add('hidden');
    }
  }

  function resetSubmitBtn() {
    submitBtn.disabled = false;
    submitBtn.textContent = w.submit;
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    if (form.elements['website'].value) return;

    const email = form.elements['email'].value.trim();
    const name = form.elements['name'].value.trim();

    if (!email) {
      showStatus(w.errorValidation, null, true);
      return;
    }

    submitBtn.disabled = true;
    submitBtn.textContent = w.submitting;

    try {
      const res = await fetch(submitUrl, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          email,
          ...(name ? { name } : {}),
          lang,
        }),
      });

      const data = await res.json();
      console.log('[waitlist] response:', res.status, data);

      if (res.ok) {
        form.classList.add('hidden');
        if (data.message === 'already_confirmed') {
          showStatus(w.alreadyConfirmed, null, false);
        } else if (data.message === 'confirmation_resent') {
          showStatus(w.successTitle, w.confirmationResent, false);
        } else {
          showStatus(w.successTitle, w.successDetail, false);
        }
      } else if (res.status === 400) {
        showStatus(w.errorValidation, null, true);
        resetSubmitBtn();
      } else if (res.status === 429) {
        showStatus(w.errorRateLimit, null, true);
        resetSubmitBtn();
      } else {
        showStatus(w.errorServer, null, true);
        resetSubmitBtn();
      }
    } catch (err) {
      console.error('[waitlist] fetch error:', err);
      showStatus(w.errorServer, null, true);
      resetSubmitBtn();
    }
  });
</script>
