---
/**
 * Logo de la app Optim. Usa el mismo asset que Android/iOS (optim_logo.png).
 */
interface Props {
  size?: number;
  class?: string;
}
const { size = 40, class: className = '' } = Astro.props;
---

<img
  src="/optim_logo.png"
  alt=""
  width={size}
  height={size}
  class={className}
  loading="eager"
  fetchpriority="high"
  aria-hidden="true"
/>
