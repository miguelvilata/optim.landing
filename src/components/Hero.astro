---
import type { Lang } from '../i18n/index.ts';
import { t } from '../i18n/index.ts';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const tr = t(lang);
const h = tr.hero;
---

<section
  class="relative min-h-screen flex items-center bg-brand-gradient overflow-hidden pt-16"
  aria-label="Hero"
>
  <!-- Background decorations -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute top-1/4 right-0 w-96 h-96 rounded-full bg-brand-secondary opacity-5 blur-3xl"></div>
    <div class="absolute bottom-0 left-1/4 w-80 h-80 rounded-full bg-blue-400 opacity-5 blur-3xl"></div>
    <!-- Grid pattern -->
    <svg class="absolute inset-0 w-full h-full opacity-5" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="grid" width="60" height="60" patternUnits="userSpaceOnUse">
          <path d="M 60 0 L 0 0 0 60" fill="none" stroke="white" stroke-width="0.5"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#grid)" />
    </svg>
  </div>

  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-32">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">

      <!-- Left: text content -->
      <div class="text-center lg:text-left">
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-white/10 border border-white/20 text-sm text-white/90 mb-8">
          <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse" aria-hidden="true"></span>
          {h.badge}
        </div>

        <!-- Headline -->
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white leading-tight tracking-tight mb-4">
          {h.title}
          <span class="block text-brand-secondary">{h.titleHighlight}</span>
        </h1>

        <!-- Subtitle -->
        <p class="text-lg sm:text-xl text-white/70 leading-relaxed mb-10 max-w-lg mx-auto lg:mx-0">
          {h.subtitle}
        </p>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
          <a
            href={`/${lang}/waitlist`}
            class="inline-flex items-center gap-3 px-6 py-3.5 bg-white text-brand-primary font-bold rounded-2xl hover:bg-brand-light transition-all duration-200 shadow-lg hover:-translate-y-0.5"
          >
            <svg class="w-5 h-5 flex-shrink-0 text-brand-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
            </svg>
            {h.cta}
          </a>
        </div>
        <!-- Secondary link -->
        <a
          href={`/${lang}#${tr.anchors.features}`}
          class="inline-flex items-center gap-1.5 mt-4 text-sm text-white/50 hover:text-white/80 transition-colors"
        >
          {h.ctaSecondary}
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </a>

        <!-- Trust note -->
        <p class="mt-8 text-sm text-white/40 flex items-center gap-2 justify-center lg:justify-start">
          <svg class="w-4 h-4 text-green-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
            <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
          </svg>
          {h.trustedBy}
        </p>
      </div>

      <!-- Right: App mockup -->
      <div class="flex justify-center lg:justify-end" aria-hidden="true">
        <div class="relative animate-float">
          <!-- Phone frame -->
          <div class="relative w-64 sm:w-72 mx-auto">
            <div class="bg-brand-dark rounded-[3rem] p-3 shadow-2xl shadow-black/50 border border-white/10">
              <div class="bg-white rounded-[2.5rem] overflow-hidden" style="height: 520px;">
                <!-- Status bar -->
                <div class="bg-brand-primary px-6 pt-4 pb-2 flex justify-between items-center">
                  <span class="text-white text-xs font-medium">9:41</span>
                  <div class="w-20 h-6 bg-black rounded-full mx-auto -mt-2"></div>
                  <div class="flex gap-1.5">
                    <div class="w-3 h-3 rounded-full bg-white/60"></div>
                    <div class="w-4 h-3 rounded bg-white/60"></div>
                  </div>
                </div>

                <!-- App header -->
                <div class="bg-brand-primary px-5 py-4">
                  <p class="text-white/60 text-xs">Bienvenido</p>
                  <h2 class="text-white text-lg font-bold">Optim</h2>
                </div>

                <!-- Summary card -->
                <div class="px-4 pt-4">
                  <div class="bg-gradient-to-r from-brand-secondary to-blue-400 rounded-2xl p-4 text-white shadow-md">
                    <p class="text-xs text-white/70 mb-1">Gasto mensual</p>
                    <p class="text-3xl font-bold">€ 284</p>
                    <div class="flex gap-3 mt-3">
                      <div class="flex-1 bg-white/20 rounded-xl p-2 text-center">
                        <p class="text-xs text-white/70">Seguros</p>
                        <p class="text-sm font-bold">€ 210</p>
                      </div>
                      <div class="flex-1 bg-white/20 rounded-xl p-2 text-center">
                        <p class="text-xs text-white/70">Gastos</p>
                        <p class="text-sm font-bold">€ 74</p>
                      </div>
                    </div>
                  </div>
                </div>

                <!-- Policy list -->
                <div class="px-4 pt-4 space-y-2">
                  {[
                    { icon: '🚗', name: 'Seguro Auto', date: '15 mar', color: 'bg-blue-50' },
                    { icon: '🏠', name: 'Seguro Hogar', date: '2 abr', color: 'bg-green-50' },
                    { icon: '❤️', name: 'Seguro Vida', date: '20 abr', color: 'bg-red-50' },
                  ].map(item => (
                    <div class={`flex items-center gap-3 p-3 rounded-xl ${item.color}`}>
                      <span class="text-xl">{item.icon}</span>
                      <div class="flex-1">
                        <p class="text-xs font-semibold text-gray-800">{item.name}</p>
                        <p class="text-xs text-gray-400">Vence {item.date}</p>
                      </div>
                      <div class="w-2 h-2 rounded-full bg-green-400"></div>
                    </div>
                  ))}
                </div>
              </div>
            </div>

            <!-- Floating badges -->
            <div class="absolute -right-6 top-16 bg-white rounded-2xl px-3 py-2 shadow-xl border border-gray-100">
              <div class="flex items-center gap-2">
                <div class="w-8 h-8 rounded-full bg-green-100 flex items-center justify-center">
                  <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
                  </svg>
                </div>
                <div>
                  <p class="text-xs font-bold text-gray-800">Ahorro</p>
                  <p class="text-xs text-green-600 font-semibold">€ 48/mes</p>
                </div>
              </div>
            </div>

            <div class="absolute -left-8 bottom-24 bg-white rounded-2xl px-3 py-2 shadow-xl border border-gray-100">
              <div class="flex items-center gap-2">
                <div class="w-8 h-8 rounded-full bg-orange-100 flex items-center justify-center">
                  <svg class="w-4 h-4 text-orange-500" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M10 2a6 6 0 00-6 6v3.586l-.707.707A1 1 0 004 14h12a1 1 0 00.707-1.707L16 11.586V8a6 6 0 00-6-6zM10 18a3 3 0 01-3-3h6a3 3 0 01-3 3z" />
                  </svg>
                </div>
                <div>
                  <p class="text-xs font-bold text-gray-800">Alerta</p>
                  <p class="text-xs text-orange-500 font-semibold">5 dias</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- Bottom wave -->
  <div class="absolute bottom-0 left-0 right-0" aria-hidden="true">
    <svg viewBox="0 0 1440 80" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" class="w-full h-16 sm:h-20">
      <path d="M0 80L60 70C120 60 240 40 360 35C480 30 600 40 720 45C840 50 960 50 1080 43C1200 36 1320 22 1380 15L1440 8V80H0Z" fill="white"/>
    </svg>
  </div>
</section>
