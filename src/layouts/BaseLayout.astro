---
import type { Lang } from '../i18n/index.ts';
import { getAlternateUrls, pathWithoutTrailingSlash } from '../i18n/index.ts';
import { SITE_URL, ANALYTICS_DOMAIN } from '../config.ts';
import { getEncodedLegal } from '../config-sensitive.ts';

const encodedLegal = getEncodedLegal();

interface Props {
  lang: Lang;
  title: string;
  description: string;
  ogTitle?: string;
  ogDescription?: string;
  canonicalPath?: string;
  /** Si se define, se usan estas URLs para hreflang en lugar de derivarlas del canonicalPath. */
  customAlternates?: Array<{ lang: Lang; url: string }>;
}

const {
  lang,
  title,
  description,
  ogTitle,
  ogDescription,
  canonicalPath = pathWithoutTrailingSlash(Astro.url.pathname),
  customAlternates,
} = Astro.props;

const canonicalURL = `${SITE_URL}${canonicalPath}`;
const ogImageURL = `${SITE_URL}/og-image.svg`;
const alternates = customAlternates ?? getAlternateUrls(canonicalPath, SITE_URL);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta name="robots" content="index, follow" />

    <!-- Alternate languages (hreflang) -->
    {alternates.map(({ lang: l, url }) => (
      <link rel="alternate" hreflang={l} href={url} />
    ))}
    <link rel="alternate" hreflang="x-default" href={`${SITE_URL}/es`} />

    <!-- OpenGraph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Optim" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={ogTitle || title} />
    <meta property="og:description" content={ogDescription || description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={lang} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle || title} />
    <meta name="twitter:description" content={ogDescription || description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <!-- Analytics (Plausible) — configure PUBLIC_ANALYTICS_DOMAIN env var to enable -->
    {ANALYTICS_DOMAIN && (
      <script
        defer
        data-domain={ANALYTICS_DOMAIN}
        src="https://plausible.io/js/script.js"
      />
    )}
  </head>
  <body class="bg-white text-gray-900 font-sans antialiased">
    <slot />
    <!-- Inyección de datos sensibles (visible para usuarios, no en HTML plano para bots) -->
    <script define:vars={{ base64Owner: encodedLegal.owner, base64Nif: encodedLegal.nif }}>
      (function () {
        function decodeUtf8B64(s) {
          try {
            return decodeURIComponent(escape(atob(s)));
          } catch (_) {
            return '';
          }
        }
        var owner = decodeUtf8B64(base64Owner);
        var nif = decodeUtf8B64(base64Nif);
        var emailUser = 'privacidad', emailDomain = 'getoptim' + '.' + 'app';
        var email = emailUser + '@' + emailDomain;
        var domain = 'getoptim' + '.' + 'app';
        document.querySelectorAll('[data-sensitive="owner"]').forEach(function (el) { el.textContent = owner; });
        document.querySelectorAll('[data-sensitive="nif"]').forEach(function (el) { el.textContent = nif; });
        document.querySelectorAll('[data-sensitive="domain"]').forEach(function (el) { el.textContent = domain; });
        document.querySelectorAll('[data-sensitive="email"]').forEach(function (el) {
          el.href = 'mailto:' + email;
          el.textContent = email;
        });
        document.querySelectorAll('[data-sensitive="domain-link"]').forEach(function (el) {
          el.href = 'https://' + domain;
          el.textContent = domain;
        });
      })();
    </script>
  </body>
</html>
