---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LegalPage from '../../components/LegalPage.astro';
import { t, getTermsPageAlternates } from '../../i18n/index.ts';
import { SITE_URL } from '../../config.ts';

const lang = 'es';
const tr = t(lang);
const { title, lastUpdated, sections } = tr.legal.terms;
---

<BaseLayout
  lang={lang}
  title={`${title} | Optim`}
  description={tr.meta.description}
  canonicalPath="/es/terminos-y-condiciones"
  customAlternates={getTermsPageAlternates(SITE_URL)}
>
  <LegalPage lang={lang} title={title} lastUpdated={lastUpdated} sections={sections} />
</BaseLayout>
