---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LegalPage from '../../components/LegalPage.astro';
import { t } from '../../i18n/index.ts';

const lang = 'es';
const tr = t(lang);
const { title, content } = tr.legal.privacy;
---

<BaseLayout
  lang={lang}
  title={`${title} | Optim`}
  description={tr.meta.description}
  canonicalPath="/es/privacy/"
>
  <LegalPage lang={lang} title={title} content={content} />
</BaseLayout>
