---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContactPage from '../../components/ContactPage.astro';
import { t, getContactPageAlternates } from '../../i18n/index.ts';
import { SITE_URL } from '../../config.ts';

const lang = 'es';
const tr = t(lang);
const c = tr.contact;
---

<BaseLayout
  lang={lang}
  title={c.metaTitle}
  description={c.metaDescription}
  canonicalPath="/es/contactar"
  customAlternates={getContactPageAlternates(SITE_URL)}
>
  <ContactPage lang={lang} />
</BaseLayout>
