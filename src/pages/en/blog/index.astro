---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BlogCard from '../../../components/BlogCard.astro';
import Navbar from '../../../components/Navbar.astro';
import Footer from '../../../components/Footer.astro';
import { t } from '../../../i18n/index.ts';

const lang = 'en';
const tr = t(lang);
const now = new Date();

const posts = await getCollection('blog', (post) =>
  post.data.lang === lang && !post.data.draft && post.data.pubDate <= now
);
posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  lang={lang}
  title={tr.blog.metaTitle}
  description={tr.blog.metaDescription}
  canonicalPath="/en/blog"
>
  <Navbar lang={lang} />
  <main class="pt-24 pb-16 bg-brand-surface min-h-screen">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <header class="mb-12 text-center">
        <h1 class="text-4xl font-extrabold text-brand-primary mb-3">{tr.blog.title}</h1>
        <p class="text-brand-muted text-lg max-w-xl mx-auto">{tr.blog.subtitle}</p>
      </header>

      {posts.length === 0 ? (
        <p class="text-center text-brand-muted py-16">{tr.blog.noPostsYet}</p>
      ) : (
        <ul class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8 list-none p-0 m-0">
          {posts.map((post) => (
            <li>
              <BlogCard
                lang={lang}
                slug={post.slug.split('/').at(-1)!}
                title={post.data.title}
                description={post.data.description}
                pubDate={post.data.pubDate}
                tags={post.data.tags}
                image={post.data.image}
              />
            </li>
          ))}
        </ul>
      )}
    </div>
  </main>
  <Footer lang={lang} />
</BaseLayout>
